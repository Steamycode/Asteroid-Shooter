import math
import pygame

WIDTH = 1280
HEIGHT = 720

pygame.display.set_caption('Asteroids')

window = pygame.display.set_mode((WIDTH, HEIGHT))
clock = pygame.time.Clock()

run = True
gameover = False

class Player(object):
    pass

player = Player()

def draw_window():
    window.fill((0, 0, 0))

    pygame.display.update()

while run:
    clock.tick(60)
    if not gameover:
        pass

    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            run = False

    draw_window()

pygame.quit()
